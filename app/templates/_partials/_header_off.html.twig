<header class="container">
	<div class="row">
		<nav
			class="navbar navbar-expand-lg col-11 col-md-12 m-auto">
			<!-- Début de la barre de navigation -->
			<div class="container-fluid">
				<a class="navbar-brand" href="{{ path('app_main') }}">
					<img src="{{ asset('images/logo.png') }}" alt="logo du site" width="100%" height="auto"/>
				</a>
				<div class="d-none d-lg-flex" id="list_options">
					{% include '_partials/_list_options.html.twig' %}
				</div>
				<div class="d-flex align-items-center">
					<button class="btn" id="theme-mode" type="button">
						<svg width="40px" height="40px" fill="yellow">
							<use href="{{ asset('images/sprites.svg') }}#light"></use>
						</svg>
					</button>
					<div class="" id="navbar">
						<button id="burger" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvas" aria-controls="offcanvas">
							<svg width="30" height="30">
    							<use href="{{ asset('images/sprites.svg') }}#burger"></use>
  							</svg>
						</button>

						<div class="offcanvas offcanvas-start" data-bs-scroll="true" tabindex="-1" id="offcanvas" aria-labelledby="offcanvasLabel">
							<div class="offcanvas-header">
								<h5 class="offcanvas-title" id="offcanvasLabel">Tech-school
								</h5>
								<button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
							</div>
							<div class="offcanvas-body">
								<div class="">
									<ul class="list-unstyled">
										{% if is_granted('IS_AUTHENTICATED_FULLY') %}
											{% if is_granted('ROLE_ADMIN') %}
												<li><a href="{{ path('app_admin')}}">Dashboard</a></li>
												<li><a href="{{ path('app_admin_timer') }}">Horaires</a></li>
												<li><a href="{{ path('app_admin_add_subject') }}">Matière</a></li>
												<li><a href="">Cours</a></li>
												<li><a href="{{ path('app_admin_school_fees') }}">Frais</a></li>
												<li><a href="{{ path('app_logout') }}">Logout</a></li>
											{% elseif is_granted('ROLE_TEACHER') %}
												<li><a href="{{ path('app_teacher')}}">Accueil</a></li>
												<li><a href="{{ path('app_teacher_add_ressource') }}">Documents</a></li>
												<li><a href="{{ path('app_teacher_notes') }}">Notes</a></li>
												<li><a href="{{ path('app_logout') }}">Logout</a></li>
											{% elseif is_granted('ROLE_PARENT') %}
												<li><a href="{{ path('app_parents')}}">Accueil</a></li>
												<li><a href="{{ path('app_parents_show_facture') }}">Factures</a></li>
												<li><a href="{{ path('app_logout') }}">Logout</a></li>
											{% elseif is_granted('ROLE_USER') %}
												<li><a href="{{ path('app_profile') }}">Accueil</a></li>
												<li><a href="">Tous les cours</a></li>
												<li><a href="{{ path('app_profile') }}#contact">Contact_Admin</a></li>
												<li><a href="{{ path('app_logout') }}">Logout</a></li>
											{% endif %}
										{% else %}
											<li><a class="active" href="{{ path('app_main')}}">Accueil</a></li>
											<li><a class="" href="{{ path('app_about') }}">Apropos</a></li>
											<li><a class="" href="{{ path('app_register') }}">Signup</a></li>
											<li><a class="" href="{{ path('app_login') }}">Login</a></li>
											{#{% set current_path = app.request.attributes.get('_route') %}
											<li>
												{% if current_path == 'app_main' %}
													<a class="" href="#contact" data-bs-dismiss="offcanvas">Contacts</a>
												{% else %}
													<a class="" href="{{ path('app_main') }}#contact">Contact</a>
												{% endif %}
											</li>#}
										{% endif %}
									</ul>
								</div>
							</div>
						</div>
					</div>

				</div>
			</div>
		</nav>
	</div>
	<!-- Fin de la barre de navigation -->
</header>
